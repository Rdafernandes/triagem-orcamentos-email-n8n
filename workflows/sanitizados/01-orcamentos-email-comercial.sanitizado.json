                  {
                      "parameters":  {
                                         "assignments":  {
                                                             "assignments":  [
                                                                                 {
                                                                                     "id":  "ba6e7a1c-3b83-404c-8f6b-819d87bc2474",
                                                                                     "name":  "mensagem_whatsapp",
                                                                                     "value":  "={{ [\n\u0027📧 *Novo pedido de orçamento recebido em \u003cCAIXA_MONITORADA\u003e*\u0027,\n\u0027\u0027,\n`👤 Contato: ${$(\u0027Basic LLM Chain\u0027).item.json.nome_contato ?? \u0027-\u0027}`,\n`🏢 Empresa: ${$(\u0027Basic LLM Chain\u0027).item.json.empresa ?? \u0027-\u0027}`,\n`⏰ Recebido: ${$(\u0027Basic LLM Chain\u0027).item.json.data_recebido ? DateTime.fromISO($(\u0027Basic LLM Chain\u0027).item.json.data_recebido).toFormat(\u0027dd/MM/yyyy\u0027) : \u0027-\u0027} às ${$(\u0027Basic LLM Chain\u0027).item.json.hora_recebido ?? \u0027-\u0027}`,\n`📩 Assunto: ${$(\u0027Get Message Content\u0027).item.json.subject ?? \u0027-\u0027}`,\n\u0027\u0027,\nString($(\u0027Basic LLM Chain\u0027).item.json.resumo ?? \u0027\u0027).replace(/^\\s+/, \u0027\u0027)\n].join(\u0027\\n\u0027) }}",
                                                                                     "type":  "string"
                                                                                 }
                                                                             ]
                                                         },
                                         "options":  {

                                                     }
                                     },
                      "type":  "n8n-nodes-base.set",
                      "typeVersion":  3.4,
                      "position":  [
                                       1632,
                                       -720
                                   ],
                      "name":  "Estruturar mensagem"
                  },
                  {
                      "parameters":  {
                                         "mode":  "runOnceForEachItem",
                                         "jsCode":  "const msg = $(\u0027Get Message Content\u0027).item.json;\n\nfunction htmlToText(html) {\n  return String(html || \u0027\u0027)\n    .replace(/\u003cstyle[\\s\\S]*?\u003c\\/style\u003e/gi, \u0027 \u0027)\n    .replace(/\u003cscript[\\s\\S]*?\u003c\\/script\u003e/gi, \u0027 \u0027)\n    .replace(/\u003cbr\\s*\\/?\u003e/gi, \u0027\\n\u0027)\n    .replace(/\u003c\\/p\u003e/gi, \u0027\\n\u0027)\n    .replace(/\u003c\\/div\u003e/gi, \u0027\\n\u0027)\n    .replace(/\u003c[^\u003e]+\u003e/g, \u0027 \u0027)\n    .replace(/\u0026nbsp;/gi, \u0027 \u0027)\n    .replace(/\u0026amp;/gi, \u0027\u0026\u0027)\n    .replace(/\u0026lt;/gi, \u0027\u003c\u0027)\n    .replace(/\u0026gt;/gi, \u0027\u003e\u0027)\n    .replace(/\\r/g, \u0027\u0027)\n    .replace(/[ \\t]+\\n/g, \u0027\\n\u0027)\n    .replace(/\\n{3,}/g, \u0027\\n\\n\u0027)\n    .replace(/[ \\t]{2,}/g, \u0027 \u0027)\n    .trim();\n}\n\nfunction extractLatestMessage(text) {\n  const patterns = [\n    /(?:^|\\n)\\s*-{2,}\\s*Mensagem encaminhada\\s*-{2,}/i,\n    /(?:^|\\n)\\s*-{2,}\\s*Forwarded message\\s*-{2,}/i,\n    /(?:^|\\n)\\s*-{2,}\\s*Original Message\\s*-{2,}/i,\n    /(?:^|\\n)\\s*Em\\s+.+?escreveu:/i,\n    /(?:^|\\n)\\s*On\\s+.+?wrote:/i,\n    /(?:^|\\n)\\s*De:\\s.+/i,\n    /(?:^|\\n)\\s*From:\\s.+/i,\n    /(?:^|\\n)\\s*Enviado:\\s.+/i,\n    /(?:^|\\n)\\s*Sent:\\s.+/i,\n  ];\n\n  let cutIndex = text.length;\n\n  for (const re of patterns) {\n    const m = re.exec(text);\n    if (m \u0026\u0026 typeof m.index === \u0027number\u0027 \u0026\u0026 m.index \u003c cutIndex) {\n      cutIndex = m.index;\n    }\n  }\n\n  return text.slice(0, cutIndex).trim();\n}\n\nconst rawSubject = String(msg.subject || \u0027\u0027).trim();\nconst subjectBase = rawSubject.replace(/^\\s*((re|res|aw|fwd|fw)\\s*:\\s*)+/gi, \u0027\u0027).trim();\nconst isReplyOrForward = rawSubject !== subjectBase;\n\nconst rawBody =\n  String(msg.text || \u0027\u0027).trim() ||\n  htmlToText(msg.html || msg.textAsHtml || \u0027\u0027);\n\nconst bodyLimpo = extractLatestMessage(rawBody);\n\nconst subjectRegex = /(orçamento|orcamento|cotação|cotacao)/i;\nconst bodyRegex = /(orçamento|orcamento|cotação|cotacao|pedido de orçamento|solicito orçamento|favor orçar|preciso de orçamento|cotação para|orcamento para|poderia enviar orçamento)/i;\n\nconst subjectMatch = subjectRegex.test(subjectBase);\nconst bodyMatch = bodyRegex.test(bodyLimpo);\n\nconst ehCandidatoOrcamento = !isReplyOrForward \u0026\u0026 (subjectMatch || bodyMatch);\n\nreturn {\n  json: {\n    ehCandidatoOrcamento,\n    subjectMatch,\n    bodyMatch,\n    isReplyOrForward,\n    subjectBase,\n    bodyLimpo,\n  },\n};"
                                     },
                      "name":  "Pré-Filtro",
                      "type":  "n8n-nodes-base.code",
